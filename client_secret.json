from googleapiclient.discovery import build
from oauth2client.file import Storage
from oauth2client.client import flow_from_clientsecrets
from oauth2client.tools import run_flow

BLOG_ID = "YOUR_BLOG_ID"  # Replace with your Blogger Blog ID

def publish_post(title, content):
    flow = flow_from_clientsecrets(
        "client_secret.json",
        scope="https://www.googleapis.com/auth/blogger"
    )
    storage = Storage("token.dat")
    credentials = storage.get()
    if credentials is None or credentials.invalid:
        credentials = run_flow(flow, storage)
    
    service = build("blogger", "v3", credentials=credentials)
    
    post = {"title": title, "content": content}
    service.posts().insert(blogId=BLOG_ID, body=post, isDraft=False).execute()
    
    print(f"Post '{title}' published successfully!")

# Example usage
if __name__ == "__main__":
    title = "My First AI-Generated Blog Post"
    content = "This post was automatically published by my AI Marketing Agent."
    publish_post(title, content)
